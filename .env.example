# Firebase Web app config (Project settings → Your apps → Web).
# Create a Web app in Firebase Console for project "nganime-site" and enable Google Analytics.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=nganime-site.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nganime-site
VITE_FIREBASE_STORAGE_BUCKET=nganime-site.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
