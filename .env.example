# Firebase Web app config (Project settings → Your apps → Web).
# Create a Web app in Firebase Console for project "pankobite" and enable Google Analytics.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=pankobite.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=pankobite
VITE_FIREBASE_STORAGE_BUCKET=pankobite.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Set to true for local DebugView (see scripts/enable-analytics-debug.ps1)
VITE_FIREBASE_ANALYTICS_DEBUG=
# Google Search Console → HTML tag verification → paste the content= value only
VITE_GOOGLE_SITE_VERIFICATION=
